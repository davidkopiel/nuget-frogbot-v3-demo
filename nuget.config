<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Local feed for Davidko.InternalUtils, a self-compiled package that is
         never published anywhere public. Used to see how Frogbot handles a
         closed-source dependency it cannot resolve against public advisory data. -->
    <add key="local-packages" value="./local-packages" />
  </packageSources>
</configuration>
